<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.sd3lab.HelloController" 
      stylesheets="@style.css" spacing="0" prefWidth="800" prefHeight="600">
    
    <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
        <Label text="Dracarys" styleClass="logo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Home" styleClass="nav-link" onAction="#showMain"/>
        <Button text="About" styleClass="nav-link" onAction="#showAbout"/>
        <Button text="Login" styleClass="nav-link" onAction="#showLogin"/>
        <Button text="Sign Up" styleClass="btn-primary" onAction="#showSignup"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox alignment="TOP_CENTER" spacing="40">
            <padding><Insets top="50" right="50" bottom="50" left="50"/></padding>

            <VBox alignment="CENTER" spacing="20">
                <Label text="Our Mission" style="-fx-font-size: 32px; -fx-font-weight: 800;"/>
                <Label text="Free. Accessible. Fun." style="-fx-font-size: 20px; -fx-text-fill: #ff4d4d; -fx-font-weight: bold;"/>
                <Label text="We believe that high-quality education should be a right, not a privilege. Our mission is to bridge the gap between expensive classes and the students who need them most." 
                       wrapText="true" textAlignment="CENTER" maxWidth="700" styleClass="hero-text"/>
            </VBox>

            <Separator/>

            <VBox alignment="CENTER" spacing="30">
                <Label text="Meet the Team" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                
                <!-- Simple 2x2 grid for team members -->
                <GridPane hgap="20" vgap="20" alignment="CENTER">
                    <VBox styleClass="card" spacing="10" alignment="CENTER" prefWidth="180" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Circle radius="30" fill="#ff4d4d"/>
                        <Label text="Suprem Karki" style="-fx-font-weight: bold;"/>
                        <Label text="Cyber Specialist" style="-fx-font-size: 12px;"/>
                    </VBox>
                    <VBox styleClass="card" spacing="10" alignment="CENTER" prefWidth="180" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Circle radius="30" fill="#ff4d4d"/>
                        <Label text="Sadun Dewage" style="-fx-font-weight: bold;"/>
                        <Label text="Design Specialist" style="-fx-font-size: 12px;"/>
                    </VBox>
                    <VBox styleClass="card" spacing="10" alignment="CENTER" prefWidth="180" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Circle radius="30" fill="#ff4d4d"/>
                        <Label text="Raja Shah" style="-fx-font-weight: bold;"/>
                        <Label text="DB Specialist" style="-fx-font-size: 12px;"/>
                    </VBox>
                    <VBox styleClass="card" spacing="10" alignment="CENTER" prefWidth="180" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Circle radius="30" fill="#ff4d4d"/>
                        <Label text="Aman Lamjel" style="-fx-font-weight: bold;"/>
                        <Label text="CS Student" style="-fx-font-size: 12px;"/>
                    </VBox>
                </GridPane>
            </VBox>
        </VBox>
    </ScrollPane>

    <HBox styleClass="footer">
        <Label text="© 2026 Dracarys | Empowering Education Through Community"/>
    </HBox>
</VBox>
