<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.sd3lab.HelloController" 
      stylesheets="@style.css" spacing="0" prefWidth="800" prefHeight="600">
    
    <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
        <Label text="Dracarys" styleClass="logo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Home" styleClass="nav-link" onAction="#showMain"/>
        <Button text="About" styleClass="nav-link" onAction="#showAbout"/>
        <Button text="Login" styleClass="nav-link" onAction="#showLogin"/>
        <Button text="Sign Up" styleClass="btn-primary" onAction="#showSignup"/>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS" style="-fx-background-color: #f1f3f5;">
        <VBox alignment="CENTER" spacing="30" styleClass="card" maxWidth="400" maxHeight="450">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
            
            <Label text="Welcome Back" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            
            <VBox spacing="10" alignment="CENTER_LEFT" fillWidth="true">
                <Label text="Username"/>
                <TextField fx:id="usernameField" promptText="Enter your username" style="-fx-padding: 10;"/>
            </VBox>
            
            <VBox spacing="10" alignment="CENTER_LEFT" fillWidth="true">
                <Label text="Password"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password" style="-fx-padding: 10;"/>
            </VBox>
            
            <Button text="Sign In" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleLogin"/>
            
            <VBox spacing="5" alignment="CENTER">
                <Hyperlink text="Forgot Password?"/>
                <HBox alignment="CENTER" spacing="5">
                    <Label text="New here?"/>
                    <Hyperlink text="Create Account" onAction="#showSignup"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>
</VBox>
