extends Layout

block head
  link(rel="stylesheet" href="/css/profile.css")
  style.
    .profile-page { padding: 40px 0; background: #f8f9fa; }
    .profile-grid { display: grid; grid-template-columns: 1fr 350px; gap: 30px; }
    .profile-section { background: white; padding: 25px; border-radius: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); margin-bottom: 30px; }
    .tutor-header { display: flex; align-items: center; gap: 20px; margin-bottom: 20px; }
    .tutor-photo { width: 100px; height: 100px; background: #00b894; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40px; font-weight: bold; }
    .tutor-tag { display: inline-block; padding: 5px 12px; background: #e0fcf6; color: #00b894; border-radius: 20px; font-size: 0.85rem; margin-right: 8px; margin-top: 10px; }
    .sidebar-booking { position: sticky; top: 20px; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
    .btn-book-trial { display: block; width: 100%; text-align: center; padding: 15px; background: linear-gradient(135deg, #00b894, #00cec9); color: white; border-radius: 8px; font-weight: bold; text-decoration: none; margin-top: 20px; }
    .status-badge { display: block; text-align: center; padding: 10px; border-radius: 8px; margin-bottom: 15px; font-weight: 600; }
    .status-pending { background: #fff3cd; color: #856404; }
    .status-accepted { background: #d4edda; color: #155724; }

block content
  .container.profile-page
    .profile-grid
      .profile-main
        .profile-section
          .tutor-header
            .tutor-photo
              | #{tutor.full_name ? tutor.full_name.charAt(0).toUpperCase() : 'T'}
            .tutor-info
              h1= tutor.full_name
              .tutor-rating
                span.stars(style="color: #f1c40f") ★ #{tutor.rating || 'N/A'}
                span.review-count  · #{tutor.reviews ? tutor.reviews.length : 0} reviews
                if role === 'tutee'
                  .action-buttons(style="display: flex; gap: 10px; margin-left: 15px; align-items: center;")
                    button#favBtn(data-tutor=tutor.tutor_id class=(isFavorite ? 'favorited' : '') style=`padding: 8px 14px; border: 1.5px solid ${isFavorite ? '#ff4757' : '#ff4757'}; border-radius: 6px; font-size: 0.95rem; font-weight: 700; cursor: pointer; color: ${isFavorite ? '#fff' : '#ff4757'}; background: ${isFavorite ? '#ff4757' : 'none'}; transition: all 0.2s;`)
                      span.icon(style="margin-right: 4px;") ❤
                      span.text #{isFavorite ? 'Favorited' : 'Favorite'}
                    
                    button#flagBtn(data-tutor=tutor.tutor_id class=(isFlagged ? 'flagged' : '') title="Report this tutor to admin" style=`padding: 6px 10px; border: 1.5px solid #ccc; border-radius: 6px; font-size: 0.8rem; cursor: pointer; color: ${isFlagged ? '#fff' : '#999'}; background: ${isFlagged ? '#999' : 'none'}; transition: all 0.2s;`)
                      span.icon ⚑

              if tutor.subjects
                .tutor-tags
                  each subject in tutor.subjects
                    span.tutor-tag= subject

        .profile-section
          h3 About Me
          p= tutor.description || "No biography provided yet."
        
        .profile-section
          h3 Qualifications
          p= tutor.qualification || "No qualifications listed."

        .profile-section
          h2 Reviews
          if tutor.reviews && tutor.reviews.length > 0
            each review in tutor.reviews
              .review-card(style="border-bottom: 1px solid #eee; padding-bottom: 15px; margin-bottom: 15px;")
                .review-header(style="display: flex; justify-content: space-between;")
                  strong= review.studentName || 'Anonymous'
                  span(style="color: #f1c40f") ★ #{review.rating}
                p(style="margin-top: 10px; color: #636e72;")= review.feedback
          else
            p No reviews yet.

          if role === 'tutee'
            .review-form(style="margin-top: 30px; border-top: 1px solid #eee; padding-top: 20px;")
              h4 Leave a Review (Max 200 words)
              form(action=`/tutor/${tutor.tutor_id}/review` method="POST")
                .form-group(style="margin-bottom: 10px;")
                  label(for="rating") Rating (0.0 to 5.0)
                  input(type="number" name="rating" min="0" max="5" step="0.5" required style="width: 100%; padding: 8px; margin-top: 5px; max-width: 150px;")
                .form-group(style="margin-bottom: 10px;")
                  label(for="feedback") Feedback
                  textarea(name="feedback" required rows="3" style="width: 100%; padding: 8px; margin-top: 5px;" placeholder="Write your review here...")
                button.btn-primary(type="submit" style="padding: 10px 15px; background: #00b894; color: white; border: none; border-radius: 5px; cursor: pointer;") Submit Review

      aside.profile-sidebar
        .sidebar-booking
          h3 Book a Trial
          p Start your learning journey with #{tutor.full_name} today.
          
          if existingBooking
            if existingBooking.status === 'pending'
              .status-badge.status-pending Pending Tutor Approval
            else if existingBooking.status === 'accepted'
              .status-badge.status-accepted ✅ Booking Confirmed!
            button.btn-book-trial(disabled style="opacity: 0.7; cursor: not-allowed;") Booking Submitted
          else if loggedIn
            if role === 'tutee'
              a.btn-book-trial(href=`/book_lesson/${tutor.tutor_id}`) Book Now
            else
              p.text-muted Tutors cannot book lessons.
          else
            a.btn-book-trial(href="/login") Login to Book

        .sidebar-stats(style="margin-top: 25px; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); position: sticky; top: 250px;")
          h3(style="font-size: 1.1rem; margin-bottom: 20px; color: #2d3436; border-bottom: 2px solid #f1f2f6; padding-bottom: 10px;") Stats & Goals
          .stat-row(style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px dashed #eee;")
            span(style="color: #636e72; font-size: 0.95rem;") Lessons Conducted
            strong(style="color: #00b894; font-size: 1.1rem;") #{tutor.lesson_count || 0}
          .stat-row(style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0;")
            span(style="color: #636e72; font-size: 0.95rem;") Goal Points
            strong(style="color: #ff9f43; font-size: 1.1rem;") #{tutor.points || 0}

  footer.mt-5.text-center.pb-4
    p © 2026 Dracarys | Empowering Education Through Community

block scripts
  script.
    document.addEventListener("DOMContentLoaded", () => {
      const favBtn = document.getElementById('favBtn');
      if (favBtn) {
        favBtn.addEventListener('click', async () => {
          const tutorId = favBtn.getAttribute('data-tutor');
          try {
            const res = await fetch(`/tutor/${tutorId}/favorite`, { method: 'POST' });
            if (res.ok) {
              const data = await res.json();
              const textSpan = favBtn.querySelector('.text');
              if (data.action === 'added') {
                favBtn.style.background = '#ff4757';
                favBtn.style.color = '#fff';
                textSpan.innerText = 'Favorited';
              } else {
                favBtn.style.background = 'none';
                favBtn.style.color = '#ff4757';
                textSpan.innerText = 'Favorite';
              }
            }
          } catch(e) { console.error('Error toggling favorite'); }
        });
      }

      const flagBtn = document.getElementById('flagBtn');
      if (flagBtn) {
        flagBtn.addEventListener('click', async () => {
          const tutorId = flagBtn.getAttribute('data-tutor');
          if (confirm("Are you sure you want to flag (report) this tutor for admin review?")) {
            try {
              const res = await fetch(`/tutor/${tutorId}/flag`, { method: 'POST' });
              if (res.ok) {
                const data = await res.json();
                if (data.action === 'added') {
                  flagBtn.style.background = '#999';
                  flagBtn.style.color = '#fff';
                  alert("Tutor has been flagged for review.");
                } else {
                  flagBtn.style.background = 'none';
                  flagBtn.style.color = '#999';
                  alert("Report retracted.");
                }
              }
            } catch(e) { console.error('Error toggling flag'); }
          }
        });
      }
    });
