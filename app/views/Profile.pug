extends Layout

block head
  link(rel="stylesheet" href="/css/profile.css")

block content
  .container.profile-page
    .profile-grid
      .profile-main
        .profile-section
          .tutor-header
            .tutor-photo
              | #{tutor.full_name ? tutor.full_name.charAt(0).toUpperCase() : 'T'}
            .tutor-info
              h1.tutor-name-wrapper
                | #{tutor.full_name}
                if tutor.verified
                  span.verified-badge(title="Verified by Admin")
                    span.verified-icon 
                    | Verified Tutor
              .tutor-rating
                span.stars.stars-rating ★ #{tutor.rating || 'N/A'}
                span.review-count  · #{tutor.reviews ? tutor.reviews.length : 0} reviews
                if role === 'tutee'
                  .action-buttons.profile-action-buttons
                    button#favBtn(data-tutor=tutor.tutor_id class=(isFavorite ? 'favorited' : ''))
                      span.icon ❤
                      span.text #{isFavorite ? 'Favorited' : 'Favorite'}
                    
                    button#flagBtn(data-tutor=tutor.tutor_id class=(isFlagged ? 'flagged' : '') title="Report this tutor to admin")
                      span.icon ⚑

              if tutor.subjects
                .tutor-tags
                  each subject in tutor.subjects
                    span.tutor-tag= subject

        .profile-section
          h3 About Me
          p= tutor.description || "No biography provided yet."
        
        .profile-section
          h3 Qualifications
          p= tutor.qualification || "No qualifications listed."

        .profile-section
          h2 Reviews
          if tutor.reviews && tutor.reviews.length > 0
            each review in tutor.reviews
              .review-card.review-item
                .review-header.review-item-header
                  strong= review.studentName || 'Anonymous'
                  span.stars-rating ★ #{review.rating}
                p.review-item-text= review.feedback
          else
            p No reviews yet.

          if role === 'tutee'
            .review-form.review-post-form
              h4 Leave a Review (Max 200 words)
              form(action=`/tutor/${tutor.tutor_id}/review` method="POST")
                .form-group.form-field
                  label(for="rating") Rating (0.0 to 5.0)
                  input.rating-input(type="number" name="rating" min="0" max="5" step="0.5" required)
                .form-group.form-field
                  label(for="feedback") Feedback
                  textarea.feedback-textarea(name="feedback" required rows="3" placeholder="Write your review here...")
                button.btn-primary.submit-review-btn(type="submit") Submit Review

      aside.profile-sidebar
        .sidebar-booking
          h3 Book a Lesson.
          p Start your learning journey with #{tutor.full_name} today.
          
          if existingBooking
            if existingBooking.status === 'pending'
              .status-badge.status-pending Pending Tutor Approval
            else if existingBooking.status === 'accepted'
              .status-badge.status-accepted  Booking Confirmed!
            button.btn-book-trial(disabled style="opacity: 0.7; cursor: not-allowed;") Booking Submitted
          else if loggedIn
            if role === 'tutee'
              a.btn-book-trial(href=`/book_lesson/${tutor.tutor_id}`) Book Now
            else
              p.text-muted Tutors cannot book lessons.
          else
            a.btn-book-trial(href="/login") Login to Book

        .sidebar-stats.stats-card
          h3.stats-title Stats & Goals
          .stat-row.stats-row
            span.stats-label Lessons Conducted
            strong.stats-value #{tutor.lesson_count || 0}
          .stat-row.stats-row.no-border
            span.stats-label Goal Points
            strong.stats-value.points #{tutor.points || 0}

  footer.mt-5.text-center.pb-4
    p © 2026 Dracarys | Empowering Education Through Community

block scripts
  script.
    document.addEventListener("DOMContentLoaded", () => {
      const favBtn = document.getElementById('favBtn');
      if (favBtn) {
        favBtn.addEventListener('click', async () => {
          const tutorId = favBtn.getAttribute('data-tutor');
          try {
            const res = await fetch(`/tutor/${tutorId}/favorite`, { method: 'POST' });
            if (res.ok) {
              const data = await res.json();
              const textSpan = favBtn.querySelector('.text');
              if (data.action === 'added') {
                favBtn.classList.add('favorited');
                textSpan.innerText = 'Favorited';
              } else {
                favBtn.classList.remove('favorited');
                textSpan.innerText = 'Favorite';
              }
            }
          } catch(e) { console.error('Error toggling favorite'); }
        });
      }

      const flagBtn = document.getElementById('flagBtn');
      if (flagBtn) {
        flagBtn.addEventListener('click', async () => {
          const tutorId = flagBtn.getAttribute('data-tutor');
          if (confirm("Are you sure you want to flag (report) this tutor for admin review?")) {
            try {
              const res = await fetch(`/tutor/${tutorId}/flag`, { method: 'POST' });
              if (res.ok) {
                const data = await res.json();
                if (data.action === 'added') {
                  flagBtn.classList.add('flagged');
                  alert("Tutor has been flagged for review.");
                } else {
                  flagBtn.classList.remove('flagged');
                  alert("Report retracted.");
                }
              }
            } catch(e) { console.error('Error toggling flag'); }
          }
        });
      }
    });
