extends layout

block head
    link(rel="stylesheet" href="/css/dashboard.css")

block content
    main.dashboard-container
        .dashboard-header
            h1 System Reports
            p Platform Analytics and Statistics

        .dashboard-content
            .dashboard-grid
                .dashboard-card
                    .card-icon USERS
                    h3 Total Users
                    p= totalUsers + ' Users'
                    a.btn-secondary(href="/admin/users") View All

                .dashboard-card
                    .card-icon TUTORS
                    h3 Total Tutors
                    p= totalTutors + ' Tutors'
                    a.btn-secondary(href="/admin/approve-tutors") Manage

                .dashboard-card
                    .card-icon STUDENTS
                    h3 Total Students
                    p= totalStudents + ' Students'
                    a.btn-secondary(href="#") View Details

                .dashboard-card
                    .card-icon STATS
                    h3 Platform Health
                    p= (totalUsers ? 'Active' : 'No Data')
                    a.btn-secondary(href="#") More Info

            .dashboard-section
                h2 User Breakdown by Role
                .admin-grid
                    if roleStats && roleStats.length
                        each stat in roleStats
                            .admin-card-item(style="flex-direction: row; justify-content: space-between; align-items: center;")
                                span.stat-label(style="font-weight: 600; color: #333;")= stat.role.charAt(0).toUpperCase() + stat.role.slice(1)
                                span.stat-value(style="font-size: 24px; font-weight: 700; color: #007bff;")= stat.count
                    else
                        p No role data available

            .dashboard-section
                h2 Recent Users
                .users-table
                    if recentUsers && recentUsers.length
                        table
                            thead
                                tr
                                    th User ID
                                    th Name
                                    th Email
                                    th Role
                            tbody
                                each user in recentUsers
                                    tr
                                        td= user.user_id
                                        td= user.full_name
                                        td= user.email
                                        td
                                            span.role-badge(class=`role-${user.role}`)= user.role
                    else
                        p No recent users
