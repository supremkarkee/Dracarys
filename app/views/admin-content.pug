extends layout

block head
    link(rel="stylesheet" href="/css/dashboard.css")
    link(rel="stylesheet" href="/css/admin-content.css")

block content
    main.dashboard-container
        .dashboard-header
            h1 Manage Content
            p Add, edit, and delete platform subjects

        .dashboard-content
            .dashboard-section
                h2 Add New Subject
                form#add-subject-form
                    .form-group
                        label Subject Name
                        input(type="text" name="subject_name" placeholder="Enter subject name" required)

                    .form-group
                        label Description (Optional)
                        textarea(name="description" placeholder="Enter subject description" rows="4")

                    button.btn-primary(type="submit") Add Subject

            .dashboard-section
                h2 Existing Subjects
                .subjects-list
                    if subjects && subjects.length
                        .subjects-grid
                            each subject in subjects
                                .subject-item
                                    h4= subject.subject_name
                                    p= subject.description || 'No description'
                                    button.btn-danger.delete-subject(data-subject-id=subject.subject_id) Delete
                    else
                        p No subjects found. Add one to get started!
block scripts
    script.
        document.getElementById('add-subject-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            try {
                const formData = new FormData(this);
                const json = Object.fromEntries(formData.entries());
                const response = await fetch('/admin/subjects/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(json)
                });
                const data = await response.json();
                if (data.success) {
                    alert('Subject added successfully');
                    location.reload();
                } else {
                    alert('Error: ' + data.error);
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        });

        document.querySelectorAll('.delete-subject').forEach(btn => {
            btn.addEventListener('click', async function() {
                const subjectId = this.dataset.subjectId;
                if (confirm('Are you sure you want to delete this subject?')) {
                    try {
                        const response = await fetch(`/admin/subjects/delete/${subjectId}`, {
                            method: 'POST'
                        });
                        const data = await response.json();
                        if (data.success) {
                            alert('Subject deleted successfully');
                            location.reload();
                        } else {
                            alert('Error: ' + data.error);
                        }
                    } catch (err) {
                        alert('Error: ' + err.message);
                    }
                }
            });
        });
