extends Layout

block head
    link(rel="stylesheet" href="/css/dashboard.css")

block content
    main.dashboard-container
        .dashboard-header
            h1 Support Tickets
            p Manage user support requests and issues

        .dashboard-content
            .dashboard-section
                h2 Active Tickets
                .tickets-container
                    if tickets && tickets.length
                        .admin-grid
                            each ticket in tickets
                                .admin-card-item.ticket-card
                                    h4= ticket.subject
                                    p= ticket.description
                                    .ticket-footer.ticket-footer-flex
                                        span.status-badge.status-verified= ticket.status || 'Open'
                                        button.btn-primary(onclick=`location.href='/admin/support/${ticket.id}'`) View Details
                    else
                        .admin-card-item.empty-tickets-card
                            p No support tickets at this time.
                            p.text-muted-mt Users can submit support requests and they will appear here.

            .dashboard-section
                h2 Create Support Response
                form.admin-form
                    .form-group
                        label Category
                        select(name="category")
                            option(value="") Select Category
                            option(value="bug") Bug Report
                            option(value="feature") Feature Request
                            option(value="payment") Payment Issue
                            option(value="account") Account Help
                            option(value="other") Other

                    .form-group
                        label Subject
                        input(type="text" name="subject" placeholder="Enter support subject")

                    .form-group
                        label Message
                        textarea(name="message" placeholder="Enter your message" rows="5")

                    button.btn-primary(type="submit") Send Response

block scripts
