extends layout

block head
    link(href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="/css/loginpage.css")

block content
    .main-content
        h1.hero-title Lets stand for free education together
        .login-container
            h2 Welcome Back
            form#loginForm
                .input-group
                    label(for="email") Email Address
                    input#email(type="email" placeholder="Enter your email" required)
                .input-group
                    label(for="password") Password
                    input#password(type="password" placeholder="Enter your password" required)
                button.login-btn(type="submit") Sign In
                #errorMsg.error(style="display: none;") Invalid login details
            .extra-links
                p
                    a(href="#") Forgot Password?
                p
                    a(href="/signup") Create Account

block scripts
    script.
        document.getElementById('loginForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const errorMsg = document.getElementById('errorMsg');
            const btn = document.querySelector('.login-btn');
            const originalBtnText = btn.innerText;

            btn.innerText = 'Signing In...';
            btn.style.opacity = '0.8';

            try {
                const response = await fetch('/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });

                if (response.redirected) {
                    window.location.href = response.url;
                } else {
                    const data = await response.text();
                    errorMsg.innerText = 'Invalid login details';
                    errorMsg.style.display = 'block';
                    btn.innerText = originalBtnText;
                    btn.style.opacity = '1';
                }
            } catch (err) {
                console.error('Login error:', err);
                errorMsg.innerText = 'An error occurred. Please try again.';
                errorMsg.style.display = 'block';
                btn.innerText = originalBtnText;
                btn.style.opacity = '1';
            }
        });
