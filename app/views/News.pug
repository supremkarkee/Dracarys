extends Layout

block head
  link(rel="stylesheet" href="/css/news.css")

block content

  //- BANNER
  .news-banner
    h1 News &amp; Feeds
    p Celebrating our community — Top Tutors and Leaderboard Rankings

  //- BODY
  .news-body
    //- ── MAIN CONTENT (Leaderboard) ──
    .news-main-full
      .leaderboard-section
        .lb-header
          h2 Dracarys Leaderboards
          span.lb-period Real-time Rankings

        .lb-table
          .lb-table-head
            span Rank
            span Tutor Details
            span Points
            span Sessions

          if leaderboard && leaderboard.length
            each tutor, index in leaderboard
              .lb-row(class=(index < 3 ? 'top-rank' : ''))
                .lb-rank
                  if index === 0
                    .rank-badge.gold 1
                  else if index === 1
                    .rank-badge.silver 2
                  else if index === 2
                    .rank-badge.bronze 3
                  else
                    .rank-badge.other= index + 1
                
                .lb-tutor
                  .lb-avatar(style=`background: ${index < 3 ? 'linear-gradient(135deg, #f6d365 0%, #fda085 100%)' : 'var(--bg-muted)'}`)
                    | #{tutor.initials}
                  .lb-tutor-info
                    .lb-tutor-name= tutor.name
                    .lb-tutor-sub= tutor.subject
                
                .lb-points
                  span.points-value= tutor.points
                  span.points-label pts
                
                .lb-sessions
                  span.sessions-value= tutor.sessions
                  span.sessions-label sessions
          else
            .lb-empty
              p No leaderboard data available at this time.

    //- ── CALL TO ACTION ──
    .news-cta-row
      .sidebar-card.sidebar-cta
        .sidebar-card-body
          h3 Ready to climb the ranks?
          p Share your knowledge, earn points, and help our community grow.
          a.sidebar-cta-btn(href='/signup?role=tutor') Become a Tutor

  //- FOOTER
  footer
    p © 2026 #[span Dracarys] | Empowering Education Through Community
