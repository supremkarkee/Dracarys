extends Layout

block head
  link(rel="stylesheet" href="/css/news.css")

block content

  //- BANNER
  .news-banner
    h1 News &amp; Feeds
    p Celebrating our community — Top Tutors and Leaderboard Rankings

  //- BODY
  .news-body
    if leaderboard && leaderboard.length
      //- ── FEATURED TUTOR (#1 Rank) ──
      - const topTutor = leaderboard[0]
      .congrats-header
        h2 Congratulations to our Tutor of the Week!
        p Celebrating excellence and dedication in our learning community.

      .featured-section
        .featured-card
          .featured-badge #1 RANKED
          .featured-card-content
            .featured-avatar
              | #{topTutor.initials}
            .featured-info
              .featured-name= topTutor.name
              .featured-subjects= topTutor.subject
              .featured-stats
                .stat-item
                  span.stat-val= topTutor.points
                  span.stat-label Points
                .stat-item
                  span.stat-val= topTutor.sessions
                  span.stat-label Sessions
            .featured-actions
              a.btn-view-profile(href=`/tutor/${topTutor.id}`) View Profile

    //- ── MAIN CONTENT (Leaderboard for 2nd onwards) ──
    .news-main-full
      .leaderboard-section
        .lb-header
          h2 Leaderboard Rankings
          span.lb-period Real-time
        
        .lb-table
          .lb-table-head
            span Rank
            span Tutor Details
            span Points
            span Sessions

          if leaderboard && leaderboard.length > 1
            each tutor, index in leaderboard.slice(1)
              - const rank = index + 2
              .lb-row(class=(rank <= 3 ? 'top-rank' : ''))
                .lb-rank
                  if rank === 2
                    .rank-badge.silver 2
                  else if rank === 3
                    .rank-badge.bronze 3
                  else
                    .rank-badge.other= rank
                
                .lb-tutor
                  .lb-avatar(style=`background: ${rank <= 3 ? 'linear-gradient(135deg, #0aab87 0%, #00c853 100%)' : 'var(--bg-muted)'}`)
                    | #{tutor.initials}
                  .lb-tutor-info
                    .lb-tutor-name= tutor.name
                    .lb-tutor-sub= tutor.subject
                
                .lb-points
                  span.points-value= tutor.points
                  span.points-label pts
                
                .lb-sessions
                  span.sessions-value= tutor.sessions
                  span.sessions-label sessions
          else if leaderboard && leaderboard.length === 1
            .lb-empty
              p More tutors will appear here as they join the leaderboard.
          else
            .lb-empty
              p No leaderboard data available at this time.

    //- ── CALL TO ACTION ──
    .news-cta-row
      .sidebar-card.sidebar-cta
        .sidebar-card-body
          h3 Ready to climb the ranks?
          p Share your knowledge, earn points, and help our community grow.
          a.sidebar-cta-btn(href='/signup?role=tutor') Become a Tutor

  //- FOOTER
  footer
    p © 2026 #[span Dracarys] | Empowering Education Through Community
