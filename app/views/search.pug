extends layout

block head
    link(rel="stylesheet" href="/css/styles.css")

block content
    main.search-page
        section.search-header
            .container.text-center
                h1.dynamic-header
                    span.highlight Find Your Expert
                    |  Tutor 
                p.lead.fade-up.d1 Discover top-tier educators specialized in your subjects.
                .search-box
                    form.filter-form(method="GET" action="/browse/tutors")
                        input(type="text" name="q" placeholder="Enter keywords, name or subject..." value=(query || ''))
                        button(type="submit") Search Now

        .search-layout
            aside.filters
                .filter-group
                    h3 Personal
                    a.filter-box.flag-filter(href=(flaggedOnly ? "/browse/tutors" : "/browse/tutors?flagged=true" ) class=(flaggedOnly ? 'active' : ''))
                        span.icon ⚑
                        | Flagged Tutors
                
                .filter-group
                    h3 Selection
                    .dropdown.vertical
                        button.dropdown-toggle
                            span Subject: #{selectedSubject === 'all' ? 'All' : selectedSubject}
                            i.arrow-down
                        .dropdown-menu
                            a.dropdown-item(href="/browse/tutors" class=(selectedSubject === 'all' ? 'active' : '')) All Subjects
                            if subjects
                                each subject in subjects
                                    - var sUrl = `/browse/tutors?subject=${subject.subject_name}` + (selectedLanguage !== 'all' ? `&lang=${selectedLanguage}` : '')
                                    a.dropdown-item(href=sUrl class=(selectedSubject == subject.subject_name ? 'active' : '')) #{subject.subject_name}

                    .dropdown.vertical
                        button.dropdown-toggle
                            span Language: #{selectedLanguage === 'all' ? 'All' : selectedLanguage}
                            i.arrow-down
                        .dropdown-menu
                            a.dropdown-item(href="/browse/tutors" class=(selectedLanguage === 'all' ? 'active' : '')) All Languages
                            if languages
                                each lang in languages
                                    - var lUrl = `/browse/tutors?lang=${lang}` + (selectedSubject !== 'all' ? `&subject=${selectedSubject}` : '')
                                    a.dropdown-item(href=lUrl class=(selectedLanguage == lang ? 'active' : '')) #{lang}

            section.tutor-list
                if data && data.length
                    each tutor in data
                        article.tutor-card.fade-up
                            .tutor-photo
                                span Name Icon
                            .tutor-info
                                h3.tutor-name #{tutor.full_name}
                                .tutor-subject #{tutor.teaching_subjects || 'General Tutor'}
                                .tutor-rating 
                                    span Rating: #{tutor.rating || 'N/A'}
                                p.tutor-desc #{tutor.description || 'Experienced tutor dedicated to student success.'}
                            .tutor-actions
                                a.btn-message(href=`/tutor/${tutor.tutor_id}`) View Profile
                                a.btn-trial(href=`/book_lesson/${tutor.tutor_id}`) Book Lesson
                else
                    .no-results
                        p No tutors found matching your criteria.
                        a.btn-secondary(href="/browse/tutors") View All Tutors

    script.
        document.addEventListener('DOMContentLoaded', () => {
            const dropdowns = document.querySelectorAll('.dropdown.vertical');
            
            dropdowns.forEach(dd => {
                const toggle = dd.querySelector('.dropdown-toggle');
                toggle.addEventListener('click', (e) => {
                    e.stopPropagation();
                    // Close others
                    dropdowns.forEach(other => {
                        if (other !== dd) other.classList.remove('open');
                    });
                    dd.classList.toggle('open');
                });
            });

            // Close when clicking outside
            document.addEventListener('click', () => {
                dropdowns.forEach(dd => dd.classList.remove('open'));
            });
        });
