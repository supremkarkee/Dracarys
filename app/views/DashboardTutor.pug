extends Layout

block head
    link(rel="stylesheet" href="/css/dashboard.css")

block content
    main.dashboard-container
        .dashboard-header
            h1 Tutor Dashboard
            p Welcome back, #{user.full_name}!

        .dashboard-content
            if success
                .alert.alert-success #{success}
            if error
                .alert.alert-danger #{error}
            
            .dashboard-section
                h2 Tutor Teaching History
            
            .dashboard-grid
                .dashboard-card
                    .card-icon STUDENTS
                    h3 My Students
                    p #{stats.students} Unique Students
                    a.btn-secondary(href="#my-students") View List

                .dashboard-card
                    .card-icon LESSONS
                    h3 Lessons
                    p #{stats.lessons} Completed Lessons
                    a.btn-secondary(href="/dashboard/tutor") View History

                
                .dashboard-card
                    .card-icon RATING
                    h3 My Rating
                    p #{stats.rating} / 5.0 (#{stats.reviewCount} reviews)
                    a.btn-secondary(href="#my-reviews") Read Feedback
            .dashboard-section
                h2 Pending Lesson Requests
                if bookings && bookings.length > 0
                    .bookings-list
                        each booking in bookings
                            .booking-card
                                h3 Trial Lesson Request
                                p
                                    strong Validation: 
                                    | #{booking.subject_name || 'General'} Lesson
                                p
                                    strong Student: 
                                    | #{booking.student_name}
                                p
                                    strong Lesson Date: 
                                    | #{new Date(booking.lesson_date).toLocaleDateString()}
                                p
                                    strong Lesson Time: 
                                    | #{booking.lesson_time ? booking.lesson_time.slice(0,5) : '...'} to #{booking.end_time ? booking.end_time.slice(0,5) : '...'}
                                p
                                    strong Status: 
                                    span(class=`status-badge status-${booking.status}`) #{booking.status.toUpperCase()}

                                if booking.status === 'pending'
                                    .respond-actions
                                        form(action="/booking/respond" method="POST")
                                            input(type="hidden" name="booking_id" value=booking.booking_id)
                                            input(type="hidden" name="status" value="accepted")
                                            button.btn-success(type="submit") Accept
                                        
                                        form.booking-form-inline(action="/booking/respond" method="POST")
                                            input(type="hidden" name="booking_id" value=booking.booking_id)
                                            input(type="hidden" name="status" value="declined")
                                            button.btn-danger(type="submit") Decline
                                else if booking.status === 'accepted'
                                    p.text-confirmed Booking confirmed.
                                    form(action="/dashboard/tutor/booking/complete" method="POST")
                                        input(type="hidden" name="booking_id" value=booking.booking_id)
                                        button.btn-success.btn-complete(type="submit") Mark as Completed
                                else if booking.status === 'completed'
                                    p.text-completed Lesson completed.
                                else
                                    p.text-declined Request declined.
                else
                    p No lesson requests at the moment.

            .dashboard-section#my-students
                h2 My Students
                if students && students.length > 0
                    .bookings-list
                        each student in students
                            .booking-card.student-card
                                div
                                    h3= student.full_name
                                    p
                                        strong Email: 
                                        | #{student.email}
                                    p
                                        strong Level: 
                                        | #{student.school_level || 'N/A'} (#{student.grade_level || 'N/A'})
                else
                    .booking-card.empty-state
                        p You don't have any students yet.

            .dashboard-section#my-reviews
                h2 My Reviews
                if reviews && reviews.length > 0
                    .bookings-list
                        each review in reviews
                            .booking-card
                                .review-card-header
                                    div
                                        h3= review.studentName
                                        span.review-date= new Date(review.review_date).toLocaleDateString()
                                    .review-rating-badge
                                        | #{review.rating} ★
                                p.review-feedback "#{review.feedback}"
                else
                    .booking-card.empty-state
                        p You haven't received any reviews yet.

            .dashboard-section#my-subjects
                h2 My Subjects
                .booking-card
                    if tutorProfile && tutorProfile.subjects && tutorProfile.subjects.length > 0
                        .subjects-container
                            each subject in tutorProfile.subjects
                                .subject-item
                                    span.subject-name= subject
                                    form(action="/dashboard/tutor/subject/remove" method="POST" style="margin: 0;")
                                        input(type="hidden" name="subject_name" value=subject)
                                        button.btn-remove-subject(type="submit" title="Remove subject") &times;
                    else
                        p.no-subjects-text You have not added any subjects yet.

                    form.add-subject-form(action="/dashboard/tutor/subject/add" method="POST")
                        input.subject-input(type="text" name="subject_name" placeholder="e.g. Machine Learning" required)
                        button.btn-success.btn-add-subject(type="submit") Add Subject

            .dashboard-section#edit-profile
                h2 Edit Profile
                .booking-card
                    form.edit-profile-form(action="/dashboard/tutor/profile" method="POST")
                        div
                            label.form-label-bold(for="qualification") Qualification
                            input#qualification.profile-input(type="text" name="qualification" value=(tutorProfile && tutorProfile.qualification ? tutorProfile.qualification : '') placeholder="e.g. BSc Computer Science")
                        
                        div
                            label.form-label-bold(for="languages") Languages (comma separated)
                            input#languages.profile-input(type="text" name="languages" value=(tutorProfile && tutorProfile.languages ? tutorProfile.languages.join(', ') : 'English') placeholder="e.g. English, Spanish")
                        
                        div
                            label.form-label-bold(for="description") Profile Description
                            textarea#description.profile-textarea(name="description" rows="5" placeholder="Tell students about yourself and your teaching style...") #{tutorProfile && tutorProfile.description ? tutorProfile.description : ''}
                        
                        div
                            button.btn-success.btn-save-profile(type="submit") Save Changes


