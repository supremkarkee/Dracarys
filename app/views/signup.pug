extends layout

block head
    link(href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="/css/signup.css")

block content
    .main-content
        h1.hero-title Join Dracarys
        .container
            #roleSelection
                h2 I want to join as a...
                .role-selection
                    .role-btn(onclick="selectRole('tutor')")
                        h3 Tutor
                        p Share knowledge and mentor others.
                    .role-btn(onclick="selectRole('learner')")
                        h3 Learner
                        p Find tutors and grow your skills.
                br
                a.back-link(href="/login") Already have an account? Login
            form#signupForm(onsubmit="handleSignup(event)")
                h2#formTitle Create Account
                .input-group
                    label(for="firstName") First Name
                    input#firstName(type="text" name="firstName" required)
                .input-group
                    label(for="lastName") Last Name
                    input#lastName(type="text" name="lastName" required)
                .input-group
                    label(for="email") Business Email (Gmail)
                    input#email(type="email" name="email" placeholder="example@gmail.com" required)
                .input-group
                    label(for="password") Password
                    input#password(type="password" name="password" required)
                .checkbox-group
                    input#ageCheck(type="checkbox" required)
                    label(for="ageCheck") I confirm that I am 18 years or older.
                input#selectedRole(type="hidden" name="role")
                button#submitBtn.submit-btn(type="submit") Sign Up
                div(style="text-align: center;")
                    a.back-link(href="javascript:resetSelection()") Change Role

block scripts
    script.
        function selectRole(role) {
            document.getElementById('roleSelection').style.display = 'none';
            document.getElementById('signupForm').style.display = 'block';
            document.getElementById('selectedRole').value = role;
            const title = role === 'tutor' ? 'Tutor Registration' : 'Learner Registration';
            document.getElementById('formTitle').innerText = title;
        }
        function resetSelection() {
            document.getElementById('signupForm').style.display = 'none';
            document.getElementById('roleSelection').style.display = 'block';
            document.getElementById('signupForm').reset();
        }
        async function handleSignup(event) {
            event.preventDefault();
            const btn = document.getElementById('submitBtn');
            const originalText = btn.innerText;

            const firstName = document.getElementById('firstName').value;
            const lastName = document.getElementById('lastName').value;
            const fullName = `${firstName} ${lastName}`;
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const role = document.getElementById('selectedRole').value === 'tutor' ? 'tutor' : 'tutee';

            btn.innerText = 'Creating Account...';
            btn.style.opacity = '0.8';

            try {
                const response = await fetch('/signup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullName, email, password, role })
                });

                if (response.redirected) {
                    alert('Account created successfully! Welcome to Dracarys.');
                    window.location.href = response.url;
                } else {
                    alert('Signup failed. Email might already be registered.');
                    btn.innerText = originalText;
                    btn.style.opacity = '1';
                }
            } catch (err) {
                console.error('Signup error:', err);
                alert('An error occurred. Please try again.');
                btn.innerText = originalText;
                btn.style.opacity = '1';
            }
        }
