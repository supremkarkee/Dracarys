extends site-layout
block content
    header
        .logo Dracarys
        nav
            ul
                li
                    a(href="/") Home
                li
                    a.active(href="/about") About
    main
        section.about-section
            .story
                h2 Our Mission
                .mission-statement
                    h3 Free. Accessible. Fun.
                    p
                        | We believe that high-quality education should be a right, not a privilege.
                        | Our mission is to 
                        strong bridge the gap
                        |  between traditional, expensive tuition classes
                        | and the students who need them most.
                    p
                        | By connecting passionate university students with younger pupils, we create a cycle of learning
                        | and mentorship.
                        | We aim to 
                        strong lift the financial burden
                        |  off parents' shoulders, ensuring that no
                        | child is left behind due to cost.
                    p
                        | Dracarys is more than just a platform; it's a movement to facilitate child growth and make
                        | learning an enjoyable, community-driven experience.
            .team
                center
                    h2 Meet the Team
                .team-grid
                    //- Member 1
                    .team-member
                        img.avatar(src="https://ui-avatars.com/api/?name=Suprem+karki&background=ff4d4d&color=fff" alt="Suprem karki")
                        .name Suprem karki
                        .role Cyber Security Specialist
                        p Cyber Security Student emphasing secure by design.
                    //- Member 2
                    .team-member
                        img.avatar(src="https://ui-avatars.com/api/?name=Sadun+Sudu+Dewage&background=ff4d4d&color=fff" alt="Sadun Sudu Dewage")
                        .name Sadun Sudu Dewage
                        .role Computing Student
                        p Crafting pixel-perfect experiences and intuitive user flows.
                    //- Member 3
                    .team-member
                        img.avatar(src="https://ui-avatars.com/api/?name=Raja+Shah&background=ff4d4d&color=fff" alt="Raja Shah")
                        .name Raja Shah
                        .role Computer Science Student
                        p Contributes database knowledge while supporting overall team coordination.
                    //- Member 4
                    .team-member
                        img.avatar(src="https://ui-avatars.com/api/?name=Aman+Lamjel&background=ff4d4d&color=fff" alt="Aman Lamjel")
                        .name Aman Lamjel
                        .role Computer Science Student
                        p Bringing designs to life with modern CSS and JavaScript.
    footer
        p &copy; 2026 Dracarys Team. All rights reserved.
block scripts
    script(src="/script.js")
