extends layout

block head
    link(rel="stylesheet" href="/css/dashboard.css")

block content
    main.dashboard-container
        .dashboard-header
            h1 Flagged Tutors
            p Review and manage tutors who have been flagged by students.

        .dashboard-content
            .dashboard-section
                h2 Flagged Profiles
                .users-table
                    if flaggedTutors && flaggedTutors.length
                        table
                            thead
                                tr
                                    th Tutor Name
                                    th Email
                                    th Flag Count
                                    th Actions
                            tbody
                                each tutor in flaggedTutors
                                    tr
                                        td= tutor.full_name
                                        td= tutor.email
                                        td
                                            span.flag-count(style="background: #fff5f5; color: #ff4757; padding: 4px 10px; border-radius: 12px; font-weight: bold;") #{tutor.flag_count} Flags
                                        td
                                            a.btn-view(href=`/tutor/${tutor.tutor_id}` style="margin-right: 10px; text-decoration: none; color: #1976d2; font-size: 0.9rem;") View Profile
                                            button.btn-resolve(data-tutor-id=tutor.tutor_id style="margin-right: 10px; padding: 6px 12px; background: #e0fcf6; color: #00b894; border: none; border-radius: 4px; cursor: pointer; font-size: 0.85rem;") Dismiss Flags
                                            button.btn-danger(data-user-id=tutor.user_id style="padding: 6px 12px; background: #ff4757; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.85rem;") Delete Account
                    else
                        p No tutors are currently flagged.

    style.
        .users-table {
            margin-top: 20px;
            overflow-x: auto;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            border-radius: 8px;
            overflow: hidden;
        }
        th, td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid #eee;
        }
        th {
            background: #f5f5f5;
            font-weight: 600;
            color: #333;
        }

block scripts
    script.
        // Dismiss Flags
        document.querySelectorAll('.btn-resolve').forEach(btn => {
            btn.addEventListener('click', async function() {
                const tutorId = this.dataset.tutorId;
                if (confirm('Are you sure you want to dismiss all flags for this tutor?')) {
                    try {
                        const response = await fetch(`/admin/flagged/resolve/${tutorId}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' }
                        });
                        const data = await response.json();
                        if (data.success) {
                            location.reload();
                        } else {
                            alert('Error: ' + data.error);
                        }
                    } catch (err) {
                        alert('Error: ' + err.message);
                    }
                }
            });
        });

        // Delete Account
        document.querySelectorAll('.btn-danger').forEach(btn => {
            btn.addEventListener('click', async function() {
                const userId = this.dataset.userId;
                if (confirm('CAUTION: This will permanently delete the tutor account and all associated data. Continue?')) {
                    try {
                        const response = await fetch(`/admin/users/delete/${userId}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' }
                        });
                        const data = await response.json();
                        if (data.success) {
                            alert('Tutor account deleted successfully');
                            location.reload();
                        } else {
                            alert('Error: ' + data.error);
                        }
                    } catch (err) {
                        alert('Error: ' + err.message);
                    }
                }
            });
        });
