extends layout

block head
    link(rel="stylesheet" href="/css/dashboard.css")

block content
    main.dashboard-container
        .dashboard-header
            h1 Student Dashboard
            p Welcome back, #{user.full_name}!

        .dashboard-content
            if success
                .alert.alert-success(style="color: white; background: #28a745; padding: 10px; border-radius: 5px; margin-bottom: 20px;") #{success}
            if error
                .alert.alert-danger(style="color: white; background: #dc3545; padding: 10px; border-radius: 5px; margin-bottom: 20px;") #{error}

            .dashboard-grid
                .dashboard-card
                    .card-icon LESSONS
                    h3 My Lessons
                    p #{stats.lessons} Lessons Booked
                    a.btn-secondary(href="/my_lessons") View Details

                .dashboard-card
                    .card-icon PROFILE
                    h3 My Profile
                    p School: #{tuteeProfile && tuteeProfile.school_level ? tuteeProfile.school_level : 'Not set'}
                    a.btn-secondary(href="#edit-education") Edit Education

                .dashboard-card
                    .card-icon TUTORS
                    h3 My Tutors
                    p #{stats.tutors} Tutors Assigned
                    a.btn-secondary(href="/browse/tutors") Find Tutors

            .dashboard-section
                h2 Your Current Bookings
                - const upcoming = bookings ? bookings.filter(b => new Date(b.lesson_date) >= new Date().setHours(0,0,0,0)) : [];
                if upcoming.length > 0
                    .activity-list
                        each booking in upcoming
                            .activity-item
                                .activity-info
                                    strong #{booking.subject_name || 'General'} Lesson with #{booking.tutor_name}
                                    p #{new Date(booking.lesson_date).toLocaleDateString()} | #{booking.lesson_time ? booking.lesson_time.slice(0,5) : '...'} - #{booking.end_time ? booking.end_time.slice(0,5) : '...'}
                                    
                                    if booking.status === 'declined'
                                        p(style="color: #dc3545; font-size: 0.9em; margin-top: 5px;") Booking unsuccessful.
                                        if booking.tutor_message
                                            p(style="color: #6c757d; font-style: italic; font-size: 0.85em;") Tutor Note: "#{booking.tutor_message}"

                                    if booking.status === 'accepted'
                                        p(style="color: #28a745; font-size: 0.9em; margin-top: 5px; font-weight: bold;") Booking confirmed.

                                .activity-status(style="display: flex; gap: 10px; align-items: center;")
                                    span(class=`status-badge status-${booking.status}`) #{booking.status.toUpperCase()}
                                    
                                    if booking.status === 'pending'
                                        form(action="/booking/cancel" method="POST" style="margin:0;")
                                            input(type="hidden" name="booking_id" value=booking.booking_id)
                                            button(type="submit" style="background: none; border: none; color: #dc3545; cursor: pointer; text-decoration: underline; font-size: 0.9em;") Cancel
                else
                    .activity-list
                        p No upcoming bookings yet. Start by finding a tutor! 
                        a.btn-primary(href="/browse/tutors") Browse Tutors


            .dashboard-section#edit-education
                h2 Edit Education Profile
                .booking-card
                    form(action="/dashboard/tutee/education" method="POST" style="display: flex; flex-direction: column; gap: 15px;")
                        div
                            label(for="school_level" style="font-weight: 600; display: block; margin-bottom: 5px;") School Level
                            input#school_level(type="text" name="school_level" value=(tuteeProfile && tuteeProfile.school_level ? tuteeProfile.school_level : '') placeholder="e.g. High School, University" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px;")
                        div
                            label(for="grade_level" style="font-weight: 600; display: block; margin-bottom: 5px;") Grade / Year Level
                            input#grade_level(type="text" name="grade_level" value=(tuteeProfile && tuteeProfile.grade_level ? tuteeProfile.grade_level : '') placeholder="e.g. Grade 10, Year 2" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px;")
                        div
                            button.btn-success(type="submit" style="padding: 10px 20px; font-size: 1rem;") Save Changes
