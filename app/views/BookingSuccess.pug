extends Layout

block content
    main.container
        .booking-container(style="text-align: center; max-width: 600px; margin: 100px auto; padding: 40px; background: white; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);")
            div(style="font-size: 60px; margin-bottom: 20px;") Success!
            h2 Booking Successful!
            p(style="margin: 20px 0; font-size: 18px; color: #636e72;")= message
            a.btn-primary(href="/my_lessons" style="display: inline-block; padding: 12px 25px; background: #00b894; color: white; border-radius: 8px; font-weight: 600;") View My Lessons
            a.btn-secondary(href="/tutors" style="margin-left: 10px; display: inline-block; padding: 12px 25px; border-radius: 8px;") Browse More Tutors
