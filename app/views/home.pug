extends layout

block head
    link(rel="stylesheet" href="/css/home-friend.css")

block content
    section.search-header
        .container
            h1 Find Your Perfect Tutor Today
            form.search-box(action="/browse/tutors" method="GET")
                input(type="text" name="q" placeholder="What subject do you need help with?")
                button(type="submit") Search

    section.features
        .container
            .section-head
                h2 Featured Tutors
                p Learn from our top-rated academic experts.
            
            .feature-grid
                if featuredTutors && featuredTutors.length
                    each tutor in featuredTutors
                        .feature-card.fade-up
                            .feature-img
                                span.img-icon Expert
                            .feature-body
                                .feature-tag= (tutor.subjects || "General").split(',')[0]
                                h3= tutor.full_name

                                .tutor-rating
                                    span.star Rating:
                                    | #{tutor.rating || "N/A"}
                                a.btn-secondary(href=`/tutor/${tutor.tutor_id}`) View Profile
                else
                    .no-results
                        p No tutors featured at the moment.

    section.features-more
        .container
            .feature-grid
                .feature-card.fade-up
                    img(src="/images/012.jpg" alt="Interactive")
                    h3 Interactive Learning
                    p Engaging sessions designed to help students understand and grow confidently.
                .feature-card.fade-up
                    img(src="/images/003.jpg" alt="Progress")
                    h3 Track Progress
                    p Parents and tutors can monitor performance and celebrate achievements.

    section.cta
        .container
            .cta-inner
                h2 Ready to start your learning journey?
                p.quote "The beautiful thing about learning is that no one can take it away from you."
                p.quote "Education is not the filling of a pail, but the lighting of a fire."
                p Join our growing educational community today.
                a.cta-btn(href="/signup") Join Now

    footer
        .container
            p &copy; 2026 Dracarys | Empowering Education Through Community

block scripts
    script(src="/script.js")
