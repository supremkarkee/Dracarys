extends layout

block head
  link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap")

block content
    //- HERO
    section.hero
        .hero-text
            .hero-eyebrow.fade-up.d1 Community-Powered Learning
            h1.fade-up.d2
                | Help Your Child&nbsp;
                span.highlight Learn, Create
                br
                | &amp; Grow.
            p.fade-up.d3
                | Dracarys connects your child with passionate university tutors
                | in a safe, supportive environment — completely free.
            p.quote.fade-up.d4
                | "Education is not a way to escape poverty,
                | it is a way of fighting it."
            .hero-buttons.fade-up.d5
                a.hero-btn.primary(href='/signup') Get Started Free
                a.hero-btn.outline(href='/about') Learn More
        .hero-image.fade-up.d2
            if heroImage
                img(src=heroImage alt="Students learning together")
            else
                .hero-img-box
                    span.img-icon 📚
                    | Students learning together

    //- STATS BAR
    .stats-bar
        .stats-inner
            .stat
                .stat-num #{stats ? stats.students : '500+'}
                .stat-label Active Students
            .stat
                .stat-num #{stats ? stats.tutors : '120+'}
                .stat-label Verified Tutors
            .stat
                .stat-num 100%
                .stat-label Free Forever
            .stat
                .stat-num #{stats ? stats.rating : '4.9★'}
                .stat-label Parent Rating

    //- FEATURES CARDS
    section.features-section
        .section-head
            h2 Why Parents Choose Dracarys
            p
                | Everything families need — built with
                | safety, trust, and real results in mind.
        .feature-grid
            .feature-card
                .feature-img
                    if featureImages && featureImages[0]
                        img(src=featureImages[0] alt="Safe Community")
                    else
                        | 🛡️
                .feature-body
                    h3 Safe &amp; Verified Community
                    p
                        | Every tutor is verified and all communication
                        | is monitored to ensure a secure learning
                        | environment your family can trust.
                    span.feature-tag Parent-Approved
            .feature-card
                .feature-img
                    if featureImages && featureImages[2]
                        img(src=featureImages[2] alt="Track Progress")
                    else
                        | 📈
                .feature-body
                    h3 Track Your Child's Progress
                    p
                        | Stay informed with clear progress updates so
                        | you always know how your child is developing
                        | and what they're achieving.
                    span.feature-tag Real-Time Updates
            .feature-card
                .feature-img
                    if featureImages && featureImages[1]
                        img(src=featureImages[1] alt="Interactive Learning")
                    else
                        | 🎓
                .feature-body
                    h3 Interactive &amp; Engaging Sessions
                    p
                        | Lessons designed to build confidence and
                        | curiosity — not just pass exams, but help
                        | children genuinely love learning.
                    span.feature-tag Confidence Building

    //- CTA BANNER
    section.cta
        .cta-inner
            h2 Ready to Start Your Child's Learning Journey?
            p.quote
                | "The beautiful thing about learning is that
                | no one can take it away from you."
            p.quote
                | "Education is not the filling of a pail,
                | but the lighting of a fire."
            p
                | Join hundreds of families already learning with
                | Dracarys — always free, always safe.
            a.cta-btn(href='/signup') Join Now — It's Free →

    //- FOOTER
    footer
        p © 2026 #[span Dracarys] | Empowering Education Through Community


