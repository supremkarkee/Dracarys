extends layout

block head
    link(rel="stylesheet" href="/css/styles.css")

block content
    main.search-page
        section.search-header
            .container
                h1 
                    span.highlight Browse 
                    | Tutors
                .search-box
                    form.filter-form(method="GET" action="/browse/tutors")
                        input(type="text" name="q" placeholder="Search by name or subject..." value=(query || ''))
                        button(type="submit") Search

        .search-layout
            aside.filters
                h3 Filter by Subject
                a.filter-btn(href="/browse/tutors" class=(selectedSubject === 'all' ? 'active' : '')) All Subjects
                if subjects && subjects.length
                    each subject in subjects
                        a.filter-btn(href=`/browse/tutors?subject=${subject.subject_name}` class=(selectedSubject == subject.subject_name ? 'active' : '')) #{subject.subject_name}

            section.tutor-list
                if data && data.length
                    each tutor in data
                        article.tutor-card.fade-up
                            .tutor-photo
                                span Name Icon
                            .tutor-info
                                h3.tutor-name #{tutor.full_name}
                                .tutor-subject #{tutor.subjects || 'General Tutor'}
                                .tutor-rating 
                                    span Rating: #{tutor.rating || 'N/A'}
                                p.tutor-desc #{tutor.description || 'Experienced tutor dedicated to student success.'}
                            .tutor-actions
                                a.btn-message(href=`/tutor/${tutor.user_id}`) View Profile
                                a.btn-trial(href=`/book/${tutor.user_id}`) Book Lesson
                else
                    .no-results
                        p No tutors found matching your criteria.
                        a.btn-secondary(href="/browse/tutors") View All Tutors
