doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title About Dracarys | Community Tuition Marketplace
        style.
            /* GLOBAL STYLES */
            :root {
                --primary: #E63946;
                --dark: #1D3557;
                --secondary: #457B9D;
                --accent: #A8DADC;
                --gold: #F4A261;
                --success: #2A9D8F;
                --light: #F1FAEE;
                --white: #ffffff;
                --grey: #6C757D;
                --grey-light: #f8f9fa;
                --font-family: 'Segoe UI', Arial, sans-serif;
            }
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body { font-family: var(--font-family); background-color: var(--white); color: var(--dark); line-height: 1.6; }
            .hero { background: linear-gradient(135deg, var(--dark) 0%, var(--primary) 100%); color: var(--white); padding: 100px 20px; text-align: center; }
            .hero .icon { font-size: 4rem; margin-bottom: 20px; }
            .hero h1 { font-size: 3rem; margin-bottom: 20px; font-weight: 900; letter-spacing: 1px; }
            .hero p { font-size: 1.25rem; opacity: 0.95; max-width: 700px; margin: 0 auto; }
            .mission { background: var(--light); padding: 80px 20px; text-align: center; }
            .mission h2 { color: var(--primary); font-size: 2.2rem; margin-bottom: 25px; }
            .mission p { color: #444; max-width: 800px; margin: 0 auto; line-height: 1.8; font-size: 1.1rem; }
            .stats { display: grid; grid-template-columns: repeat(3, 1fr); background: var(--dark); padding: 60px 20px; gap: 2px; }
            .stat-box { text-align: center; padding: 20px; }
            .stat-box .num { font-size: 3rem; font-weight: 900; color: var(--primary); }
            .stat-box .label { color: var(--white); opacity: 0.85; font-size: 1rem; margin-top: 10px; font-weight: 500; text-transform: uppercase; letter-spacing: 1px; }
            .team { padding: 80px 20px; text-align: center; background: var(--white); }
            .team h2 { font-size: 2.2rem; color: var(--dark); margin-bottom: 50px; }
            .team-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; max-width: 1100px; margin: 0 auto; }
            .member { text-align: center; }
            .avatar { width: 100px; height: 100px; border-radius: 50%; margin: 0 auto 15px; display: flex; align-items: center; justify-content: center; font-size: 2.2rem; font-weight: bold; color: var(--white); box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
            .member h4 { font-size: 1.1rem; color: var(--dark); margin-bottom: 5px; }
            .member .student-id { font-size: 0.85rem; color: var(--grey); font-family: monospace; }
            .member .role { font-size: 0.9rem; color: var(--primary); font-weight: 600; margin-top: 5px; }
            .values { background: var(--light); padding: 80px 20px; }
            .values h2 { text-align: center; font-size: 2.2rem; color: var(--dark); margin-bottom: 50px; }
            .values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; max-width: 1100px; margin: 0 auto; }
            .value-card { background: var(--white); padding: 30px; border-radius: 12px; border-top: 5px solid var(--primary); box-shadow: 0 4px 15px rgba(0,0,0,0.05); transition: transform 0.3s ease; }
            .value-card:hover { transform: translateY(-5px); }
            .value-card .icon { font-size: 2rem; margin-bottom: 15px; }
            .value-card h4 { color: var(--dark); margin-bottom: 10px; font-size: 1.2rem; }
            .value-card p { font-size: 0.95rem; color: var(--grey); line-height: 1.6; }
            .ethics { background: var(--dark); color: var(--white); padding: 80px 20px; text-align: center; }
            .ethics h2 { font-size: 2.2rem; color: var(--primary); margin-bottom: 25px; }
            .ethics p { opacity: 0.9; max-width: 800px; margin: 0 auto; line-height: 1.8; font-size: 1.05rem; }
            .cta { background: var(--primary); color: var(--white); padding: 80px 20px; text-align: center; }
            .cta h2 { font-size: 2.2rem; margin-bottom: 20px; }
            .cta p { opacity: 0.95; margin-bottom: 35px; font-size: 1.1rem; max-width: 600px; margin-left: auto; margin-right: auto; }
            .btn { background: var(--white); color: var(--primary); padding: 15px 35px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 1.1rem; transition: background 0.2s, color 0.2s; }
            .btn:hover { background: var(--dark); color: var(--white); }
            @media(max-width: 900px) { .values-grid { grid-template-columns: repeat(2, 1fr); } .team-grid { grid-template-columns: repeat(2, 1fr); } }
            @media(max-width: 600px) { .stats { grid-template-columns: 1fr; gap: 20px; padding: 40px 20px; } .values-grid, .team-grid { grid-template-columns: 1fr; } .hero h1 { font-size: 2.2rem; } }
    body
        header.hero
            .icon 🔥
            h1 About Dracarys
            p We believe every child deserves access to an inspiring, affordable, and safe learning experience — no matter their background or budget.

        section.mission
            h2 Our Mission
            p
                | Dracarys is a community-driven tuition marketplace built by university students, for school students.
                | We connect enthusiastic university students and subject experts with primary and secondary school pupils,
                | bridging the gap between academic levels through peer-to-peer learning.
                | Our platform makes education more 
                strong accessible
                | , more 
                strong affordable
                | , and genuinely more 
                strong fun
                | .

        section.stats
            .stat-box
                .num 10+
                .label Verified Tutors
            .stat-box
                .num 10
                .label Subjects Available
            .stat-box
                .num 100%
                .label Safety Verified

        section.team
            h2 👨‍💻 Meet the Team
            .team-grid
                .member
                    .avatar(style="background:var(--primary)") SK
                    h4 Suprem Karki
                    p.student-id A00020626
                    p.role Backend & DevOps
                .member
                    .avatar(style="background:var(--secondary)") RS
                    h4 Raja Shah
                    p.student-id A00020547
                    p.role Frontend & Design
                .member
                    .avatar(style="background:var(--success)") SS
                    h4 Sadun Sudu Dewage
                    p.student-id A00019034
                    p.role Database & Docs
                .member
                    .avatar(style="background:var(--gold)") AL
                    h4 Aman Lamjel
                    p.student-id A00016965
                    p.role Testing & Ethics

        section.ethics
            h2 🛡️ Our Commitment to Safety & Ethics
            p
                | Dracarys was designed with child safeguarding at its core. All tutors are verified with university email addresses.
                | Parents have full visibility over all messaging between tutors and their children.
                | We comply fully with GDPR — collecting only the minimum data required.
                | Our platform includes a content flagging system, moderation controls, and a clear code of conduct for all tutors.
                | We are committed to inclusivity, accessibility (WCAG 2.1 AA), and bias-free matching.

        section.cta
            h2 🔥 Ready to Join the Community?
            p Whether you're a parent looking for a tutor, or a university student wanting to give back — Dracarys is for you.
            a.btn(href="/signup") Get Started Today
