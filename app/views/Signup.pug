extends Layout

block head
    link(href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="/css/signup.css")

block content
    .main-content
        h1.hero-title Join Dracarys
        .container
            if error
                .error-message #{error}
            #roleSelection
                h2 I want to join as a...
                .role-selection
                    .role-btn(onclick="selectRole('tutor')")
                        h3 Tutor
                        p Share knowledge and mentor others.
                    .role-btn(onclick="selectRole('learner')")
                        h3 Learner
                        p Find tutors and grow your skills.
                br
                a.back-link(href="/login") Already have an account? Login
            form#signupForm(action="/signup" method="POST")
                h2#formTitle Create Account
                .form-row
                    .input-group
                        label(for="firstName") First Name
                        input#firstName(type="text" name="firstName" pattern="^[^0-9]+$" title="Names cannot contain numbers" required)
                    .input-group
                        label(for="lastName") Last Name
                        input#lastName(type="text" name="lastName" pattern="^[^0-9]+$" title="Names cannot contain numbers" required)
                .input-group
                    label(for="email") Gmail Address
                    input#email(type="email" name="email" placeholder="example@gmail.com" required)
                .input-group
                    label(for="password") Password
                    input#password(type="password" name="password" pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[\\W_]).{8,}" title="Password must be at least 8 characters long and contain uppercase, lowercase, number, and special character" required)
                .input-group
                    label(for="confirmPassword") Confirm Password
                    input#confirmPassword(type="password" name="confirmPassword" required)
                    #passwordError.password-error Passwords do not match.
                .checkbox-group
                    input#ageCheck(type="checkbox" required)
                    label(for="ageCheck") I confirm that I am 18 years or older.
                input#selectedRole(type="hidden" name="role")
                button#submitBtn.submit-btn(type="submit") Sign Up
                .center-text
                    a.back-link(href="javascript:resetSelection()") Change Role

block scripts
    script.
        function selectRole(role) {
            document.getElementById('roleSelection').classList.add('display-none');
            document.getElementById('signupForm').classList.add('display-block');
            document.getElementById('selectedRole').value = role;
            const title = role === 'tutor' ? 'Tutor Registration' : 'Learner Registration';
            document.getElementById('formTitle').innerText = title;
        }
        function resetSelection() {
            document.getElementById('signupForm').classList.remove('display-block');
            document.getElementById('roleSelection').classList.remove('display-none');
            document.getElementById('signupForm').reset();
            document.getElementById('passwordError').classList.remove('display-block');
        }

        // Real-time password matching validation
        const password = document.getElementById('password');
        const confirmPassword = document.getElementById('confirmPassword');
        const passwordError = document.getElementById('passwordError');
        const submitBtn = document.getElementById('submitBtn');

        function validatePasswords() {
            if (confirmPassword.value && password.value !== confirmPassword.value) {
                passwordError.classList.add('display-block');
                confirmPassword.classList.add('input-invalid');
                return false;
            } else {
                passwordError.classList.remove('display-block');
                confirmPassword.classList.remove('input-invalid');
                return true;
            }
        }

        password.addEventListener('input', validatePasswords);
        confirmPassword.addEventListener('input', validatePasswords);

        document.getElementById('signupForm').addEventListener('submit', function(e) {
            if (!validatePasswords()) {
                e.preventDefault();
            }
        });

