extends layout

block head
    link(rel="stylesheet" href="/css/dashboard.css")

block content
    main.dashboard-container
        .dashboard-header
            h1 Support Tickets
            p Manage user support requests and issues

        .dashboard-content
            .dashboard-section
                h2 Active Tickets
                .tickets-container
                    if tickets && tickets.length
                        .tickets-list
                            each ticket in tickets
                                .ticket-item
                                    h4= ticket.subject
                                    p= ticket.description
                                    .ticket-footer
                                        span.status= ticket.status || 'Open'
                                        button.btn-primary(onclick=`location.href='/admin/support/${ticket.id}'`) View Details
                    else
                        .no-tickets
                            p No support tickets at this time.
                            p Users can submit support requests and they will appear here.

            .dashboard-section
                h2 Create Support Response
                form.support-form
                    .form-group
                        label Category
                        select(name="category")
                            option(value="") Select Category
                            option(value="bug") Bug Report
                            option(value="feature") Feature Request
                            option(value="payment") Payment Issue
                            option(value="account") Account Help
                            option(value="other") Other

                    .form-group
                        label Subject
                        input(type="text" name="subject" placeholder="Enter support subject")

                    .form-group
                        label Message
                        textarea(name="message" placeholder="Enter your message" rows="5")

                    button.btn-primary(type="submit") Send Response

        style.
            .tickets-container {
                margin-top: 20px;
            }
            .tickets-list {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }
            .ticket-item {
                background: white;
                padding: 20px;
                border-radius: 8px;
                box-shadow: 0 2px 8px rgba(0,0,0,0.1);
                border-left: 4px solid #007bff;
            }
            .ticket-item h4 {
                margin: 0 0 10px 0;
                color: #333;
            }
            .ticket-item p {
                margin: 0 0 15px 0;
                color: #666;
            }
            .ticket-footer {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
            .ticket-footer .status {
                background: #d4edda;
                color: #155724;
                padding: 4px 12px;
                border-radius: 20px;
                font-size: 12px;
                font-weight: 600;
            }
            .no-tickets {
                text-align: center;
                padding: 40px;
                background: white;
                border-radius: 8px;
                box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            }
            .support-form {
                background: white;
                padding: 20px;
                border-radius: 8px;
                box-shadow: 0 2px 8px rgba(0,0,0,0.1);
                max-width: 600px;
                margin-top: 20px;
            }
            .form-group {
                margin-bottom: 20px;
                display: flex;
                flex-direction: column;
            }
            .form-group label {
                margin-bottom: 8px;
                font-weight: 600;
                color: #333;
            }
            .form-group input,
            .form-group select,
            .form-group textarea {
                padding: 10px;
                border: 1px solid #ddd;
                border-radius: 4px;
                font-size: 14px;
                font-family: inherit;
            }
