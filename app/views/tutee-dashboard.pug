extends site-layout

block head
    link(rel="stylesheet" href="/CSS/dashboard.css")

block content
    main.dashboard-container
        .dashboard-header
            h1 Student Dashboard
            p Welcome to your dashboard.

        .dashboard-content
            //- Stats cards
            .dashboard-grid
                .dashboard-card
                    .card-icon 📚
                    h3 My Lessons
                    p #{stats.lessons} Lessons Booked
                    a.btn-secondary(href="/browse/tutors") Find Tutors

                .dashboard-card
                    .card-icon 👨‍🏫
                    h3 My Tutors
                    p #{stats.tutors} Tutors Assigned
                    a.btn-secondary(href="/browse/tutors") Browse Tutors

                .dashboard-card
                    .card-icon ♥
                    h3 Favourites
                    p Saved tutors
                    a.btn-secondary(href="/browse/tutors?favorites=true") View Favourites

            //- Upcoming bookings
            .dashboard-section
                h2 Upcoming Bookings
                - const upcoming = bookings ? bookings.filter(b => new Date(b.lesson_date) >= new Date().setHours(0,0,0,0)) : [];
                if upcoming.length > 0
                    .activity-list
                        each b in upcoming
                            .activity-item
                                .activity-info
                                    strong #{b.subject_name || 'General'} Lesson with #{b.tutor_name}
                                    p
                                        | #{new Date(b.lesson_date).toLocaleDateString()}
                                        |  | #{b.lesson_time ? b.lesson_time.slice(0,5) : '...'} – #{b.end_time ? b.end_time.slice(0,5) : '...'}

                                    if b.status === 'declined'
                                        p(style="color:#dc3545;font-size:0.9em;") ❌ Booking unsuccessful.
                                        if b.tutor_message
                                            p(style="color:#6c757d;font-style:italic;font-size:0.85em;") Tutor note: "#{b.tutor_message}"
                                    else if b.status === 'accepted'
                                        p(style="color:#28a745;font-size:0.9em;font-weight:bold;") ✅ Confirmed!

                                .activity-status(style="display:flex;gap:10px;align-items:center;")
                                    span(class=`status-badge status-${b.status}`) #{b.status.toUpperCase()}
                                    if b.status !== 'declined'
                                        form(action="/booking/cancel" method="POST" style="margin:0;")
                                            input(type="hidden" name="booking_id" value=b.booking_id)
                                            button(type="submit" style="background:none;border:none;color:#dc3545;cursor:pointer;text-decoration:underline;font-size:0.9em;") Cancel
                else
                    p No upcoming bookings. 
                    a.btn-primary(href="/browse/tutors") Find a Tutor

            //- Past bookings
            .dashboard-section
                h2 Past Bookings
                - const past = bookings ? bookings.filter(b => new Date(b.lesson_date) < new Date().setHours(0,0,0,0)) : [];
                if past.length > 0
                    .activity-list
                        each b in past
                            .activity-item(style="opacity:0.7;")
                                .activity-info
                                    strong #{b.subject_name || 'General'} Lesson with #{b.tutor_name}
                                    p #{new Date(b.lesson_date).toLocaleDateString()} | #{b.lesson_time ? b.lesson_time.slice(0,5) : '...'}
                                .activity-status
                                    span(class=`status-badge status-${b.status}`) #{b.status.toUpperCase()}
                else
                    p No past bookings yet.