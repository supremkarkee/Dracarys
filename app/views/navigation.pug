mixin navbar(activePage)
  nav
    a.nav-logo(href='/') Drac
      span arys
    .nav-links
      a(href='/', class=activePage === 'home' ? 'active' : '') Home
      if loggedIn && user && user.role !== 'tutor'
        a(href='/browse/tutors', class=activePage === 'browse-tutors' ? 'active' : '') Search Tutors
      if !loggedIn
        a(href='/browse/tutors', class=activePage === 'browse-tutors' ? 'active' : '') Search Tutors
      a(href='/about', class=activePage === 'about' ? 'active' : '') About
      a(href='/news', class=activePage === 'news' ? 'active' : '') News &amp; Feeds
      if loggedIn
        a(href='/dashboard', class=activePage === 'dashboard' ? 'active' : '') Dashboard
      if !loggedIn
        a(href='/signup', class=activePage === 'signup' ? 'active' : '') Sign Up
    .nav-cta
      if loggedIn
        span Welcome, #{user.full_name}
        a.btn-secondary(href='/logout') Logout
      else
        a.btn-primary(href='/login') Login
