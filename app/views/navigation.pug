mixin navbar(activePage)
  nav
    a.nav-logo(href='/') Drac
      span arys
    .nav-links
      a(href='/', class=activePage === 'home' ? 'active' : '') Home
      a(href='/tutors', class=activePage === 'search' ? 'active' : '') Search Tutors
      a(href='/about', class=activePage === 'about' ? 'active' : '') About Us
      a(href='/news', class=activePage === 'news' ? 'active' : '') News &amp; Feeds
      if user && user.loggedIn
        if user.role === 'tutor'
          a(href='/tutor_dashboard', class=activePage === 'dashboard' ? 'active' : '') Dashboard
        else
          a(href='/my_lessons', class=activePage === 'my_lessons' ? 'active' : '') My Lessons
      else
        a(href='/signup', class=activePage === 'signup' ? 'active' : '') Sign Up
    .nav-cta
      if user && user.loggedIn
        a.btn-primary(href='/logout') Logout
      else
        a.btn-primary(href='/login') Login
