mixin navbar(activePage)
  nav
    a.nav-logo(href='Home.html') Drac
      span arys
    .nav-links
      a(href='Home.html', class=activePage === 'home' ? 'active' : '') Home
      a(href='tgisearch.html', class=activePage === 'search' ? 'active' : '') Search Tutors
      a(href='about.html', class=activePage === 'about' ? 'active' : '') About
      a(href='#', class=activePage === 'news' ? 'active' : '') News &amp; Feeds
      a(href='signup.html', class=activePage === 'signup' ? 'active' : '') Sign Up
    .nav-cta
      
      a.btn-primary(href='loginpage.html') Login
