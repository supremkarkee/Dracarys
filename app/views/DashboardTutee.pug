extends Layout

block head
    link(rel="stylesheet" href="/css/dashboard.css")

block content
    main.dashboard-container
        .dashboard-header
            h1 Student Dashboard
            p Welcome back, #{user.full_name}!

        .dashboard-content
            if success
                .alert.alert-success #{success}
            if error
                .alert.alert-danger #{error}

            .dashboard-grid
                .dashboard-card
                    .card-icon LESSONS
                    h3 My Lessons
                    p #{stats.lessons} Lessons Booked
                    a.btn-secondary(href="/my_lessons") View Details

                .dashboard-card
                    .card-icon PROFILE
                    h3 My Profile
                    p School: #{tuteeProfile && tuteeProfile.school_level ? tuteeProfile.school_level : 'Not set'}
                    a.btn-secondary(href="#edit-education") Edit Education

                .dashboard-card
                    .card-icon TUTORS
                    h3 My Tutors
                    p #{stats.tutors} Tutors Assigned
                    a.btn-secondary(href="/browse/tutors") Find Tutors

            .dashboard-section
                h2 Your Current Bookings
                - const upcoming = bookings ? bookings.filter(b => new Date(b.lesson_date) >= new Date().setHours(0,0,0,0)) : [];
                if upcoming.length > 0
                    .activity-list
                        each booking in upcoming
                            .activity-item
                                .activity-info
                                    strong #{booking.subject_name || 'General'} Lesson with #{booking.tutor_name}
                                    p #{new Date(booking.lesson_date).toLocaleDateString()} | #{booking.lesson_time ? booking.lesson_time.slice(0,5) : '...'} - #{booking.end_time ? booking.end_time.slice(0,5) : '...'}
                                    
                                    if booking.status === 'declined'
                                        p.text-unsuccessful Booking unsuccessful.
                                        if booking.tutor_message
                                            p.tutor-note Tutor Note: "#{booking.tutor_message}"

                                    if booking.status === 'accepted'
                                        p.text-confirmed-bold Booking confirmed.

                                .activity-status.activity-status-wrapper
                                    span(class=`status-badge status-${booking.status}`) #{booking.status.toUpperCase()}
                                    
                                    if booking.status === 'pending'
                                        form(action="/booking/cancel" method="POST" style="margin:0;")
                                            input(type="hidden" name="booking_id" value=booking.booking_id)
                                            button.btn-cancel-mini(type="submit") Cancel
                else
                    .activity-list
                        p No upcoming bookings yet. Start by finding a tutor! 
                        a.btn-primary(href="/browse/tutors") Browse Tutors


            .dashboard-section#edit-education
                h2 Edit Education Profile
                .booking-card
                    form.education-form(action="/dashboard/tutee/education" method="POST")
                        div
                            label.form-label-bold(for="school_level") School Level
                            input#school_level.profile-input(type="text" name="school_level" value=(tuteeProfile && tuteeProfile.school_level ? tuteeProfile.school_level : '') placeholder="e.g. High School, University")
                        div
                            label.form-label-bold(for="grade_level") Grade / Year Level
                            input#grade_level.profile-input(type="text" name="grade_level" value=(tuteeProfile && tuteeProfile.grade_level ? tuteeProfile.grade_level : '') placeholder="e.g. Grade 10, Year 2")
                        div
                            button.btn-success.btn-save-profile(type="submit") Save Changes
